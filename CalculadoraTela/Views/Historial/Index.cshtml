@model IEnumerable<CalculadoraTela.Models.Calculo>

@{
    ViewData["Title"] = "Historial de Cálculos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary"><i class="bi bi-clock-history"></i> Historial de Cálculos</h2>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left"></i> Volver a Calculadora
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            No hay registros guardados en el historial todavía.
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover table-striped align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Fecha</th>
                        <th>Máquina</th>
                        <th>Tejido (Urd x Trama)</th>
                        <th>Ficha Térmica (A11)</th>
                        <th>Peso Metro (gml)</th>
                        <th>Peso Bolsa (gr/Bol)</th>
                        <th>Producción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><span class="badge bg-secondary">M-@item.MaquinaNumero</span></td>
                            <td>@item.UrdimbreTejido x @item.TramaTejido</td>
                            <td><code>@item.ResumenFicha</code></td>
                            <td>@item.PesoMetroLineal.ToString("F2")</td>
                            <td>@item.PesoPorBolsa.ToString("F2")</td>
                            <td class="fw-bold text-success">@item.ProduccionEstimada.ToString("F2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>