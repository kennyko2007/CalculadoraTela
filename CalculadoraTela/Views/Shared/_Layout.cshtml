<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - CalculadoraTela</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- CSS ASP.NET -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Nuestro CSS -->
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />

    <!-- CSS generado por ASP.NET -->
    <link rel="stylesheet" href="~/CalculadoraTela.styles.css" asp-append-version="true" />
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">

            <a class="navbar-brand fw-bold"
               asp-controller="Home"
               asp-action="Index">
                <i class="bi bi-calculator-fill text-warning me-1"></i>
                Calculadora Tela
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarMenu"
                    aria-controls="navbarMenu"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMenu">
                <ul class="navbar-nav ms-auto align-items-lg-center">

                    <!-- Calculadora -->
                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Home"
                           asp-action="Index">
                            <i class="bi bi-house-door-fill me-1"></i>
                            Calculadora
                        </a>
                    </li>

                    <!-- Historial (Apunta a Home/Historial) -->
                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Home"
                           asp-action="Historial">
                            <i class="bi bi-clock-history me-1"></i>
                            Historial
                        </a>
                    </li>

                    <!-- Menú Desplegable: Operaciones -->
                    <li class="nav-item dropdown ms-lg-2">
                        <a class="nav-link dropdown-toggle text-warning fw-semibold"
                           href="#"
                           id="dropdownOperaciones"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">
                            <i class="bi bi-gear-wide-connected me-1"></i>
                            Operaciones
                        </a>
                        <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end shadow" aria-labelledby="dropdownOperaciones">
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Operaciones"
                                   asp-action="Rendimiento">
                                    <i class="bi bi-graph-up text-warning me-2"></i>
                                    Rendimiento (%)
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Operaciones"
                                   asp-action="Ausencias"
                                   asp-route-tipo="Asistencia">
                                    <i class="bi bi-person-check text-success me-2"></i>
                                    Asistencia
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Operaciones"
                                   asp-action="Ausencias"
                                   asp-route-tipo="Falta">
                                    <i class="bi bi-person-x text-danger me-2"></i>
                                    Faltas
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Operaciones"
                                   asp-action="Ausencias"
                                   asp-route-tipo="Vacaciones">
                                    <i class="bi bi-calendar-event text-info me-2"></i>
                                    Vacaciones / Bajas
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Operaciones"
                                   asp-action="Ausencias"
                                   asp-route-tipo="NoEnMaquina">
                                    <i class="bi bi-slash-circle text-warning me-2"></i>
                                    No en Máquina
                                </a>
                            </li>
                        </ul>
                    </li>

                </ul>
            </div>

        </div>
    </nav>

    <!-- CONTENIDO -->
    <div class="container-fluid px-4 mt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="footer mt-5 py-3 text-center text-muted border-top">
        <div class="container">
            © @DateTime.Now.Year - Calculadora Tela | Control de Planta
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>
