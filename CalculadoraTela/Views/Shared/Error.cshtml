@model CalculadoraTela.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container text-center my-5">
    <h1 class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Ocurrió un error</h1>
    <p class="lead text-muted">Se produjo un problema al procesar la solicitud en el servidor.</p>

    @if (Model != null && !string.IsNullOrEmpty(Model.RequestId))
    {
        <p class="small text-secondary">
            <strong>ID de la solicitud:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <a href="/" class="btn btn-primary mt-3">
        <i class="bi bi-house-door-fill"></i> Volver al Inicio
    </a>
</div>
