@model IEnumerable<CalculadoraTela.Models.Calculo>

@{
    ViewData["Title"] = "Historial de Registros";
}

<div class="container-fluid py-4 px-4" style="background-color: #f8fafc; min-height: 100vh;">
    <!-- Encabezado -->
    <div class="d-flex align-items-center justify-content-between mb-4 pb-3 border-bottom border-2">
        <h2 class="fw-bold mb-0" style="color: #0f172a;">
            <i class="bi bi-clock-history text-primary me-2"></i>Historial de Cálculos Guardados
        </h2>
        <div class="d-flex gap-2">
            @if (Model != null && Model.Any())
            {
                <button type="button" id="btnVaciarHistorial" class="btn btn-outline-danger shadow-sm px-4 fw-semibold">
                    <i class="bi bi-trash3 me-1"></i> Vaciar Historial
                </button>
            }
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary shadow-sm px-4 fw-semibold">
                <i class="bi bi-arrow-left me-1"></i> Volver a la Calculadora
            </a>
        </div>
    </div>

    <!-- Tabla de Historial -->
    <div class="card shadow-sm mb-4 border-0 rounded-3 overflow-hidden">
        <div class="card-body p-0 table-responsive bg-white">
            <table class="table table-hover table-bordered align-middle text-center mb-0 border-light" style="font-size: 0.85rem;">
                <thead class="text-white text-uppercase fs-7" style="background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%);">
                    <tr>
                        <th class="py-3">ID</th>
                        <th class="py-3">Fecha</th>
                        <th class="py-3">Tipo Producto</th>
                        <th class="py-3">Medida (Ancho x Corte)</th>
                        <th class="py-3">Tejido (U x T)</th>
                        <th class="py-3">Denier (U x T)</th>
                        <th class="py-3">Urdimbre (Res / %)</th>
                        <th class="py-3">Trama (Res / %)</th>
                        <th class="py-3">Refuerzo</th>
                        <th class="py-3">GML</th>
                        <th class="py-3">GM2</th>
                        <th class="py-3">GMP</th>
                        <th class="py-3">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-secondary">@item.Id</td>
                                <!-- Hora real (Bolivia, UTC-4), calculada a partir de la fecha
                                     guardada en UTC. No usamos ToLocalTime() porque depende de la
                                     zona horaria del servidor (en Render suele ser UTC). -->
                                <td class="fw-semibold text-dark">@item.FechaCreacionLocal.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                <td><span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle px-2 py-1">@item.TipoProducto</span></td>
                                <td class="fw-semibold">@item.Ancho.ToString("F1") x @item.Corte.ToString("F1")</td>
                                <td>@item.UrdimbreTejido.ToString("F1") x @item.TramaTejido.ToString("F1")</td>
                                <td>@item.UrdimbreDenier x @item.TramaDenier</td>
                                <td>@item.ResistenciaUrdimbre.ToString("F2") KgF (@item.PorcentajeUrdimbre.ToString("F0")%)</td>
                                <td>@item.ResistenciaTrama.ToString("F2") KgF (@item.PorcentajeTrama.ToString("F0")%)</td>
                                <td>@item.UrdimbreRefuerzoResistencia.ToString("F2") KgF</td>
                                <td class="fw-bold text-success">@item.PesoMetroLineal.ToString("F1")</td>
                                <td class="text-dark">@item.PesoTejidoBase.ToString("F1")</td>
                                <td class="fw-bold text-primary">@item.PesoPorBolsa.ToString("F1")</td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-outline-danger btn-eliminar-registro" data-id="@item.Id" title="Eliminar este registro">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="13" class="text-center py-5 text-muted">
                                <i class="bi bi-folder2-open display-5 d-block mb-2 text-secondary"></i>
                                <span class="fs-6">No hay registros guardados en el historial todavía.</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Eliminar un registro puntual
            document.querySelectorAll(".btn-eliminar-registro").forEach(function (btn) {
                btn.addEventListener("click", function () {
                    const id = btn.getAttribute("data-id");
                    if (!confirm("¿Eliminar este registro del historial? Esta acción no se puede deshacer.")) return;

                    btn.disabled = true;

                    fetch('/Home/EliminarRegistro?id=' + encodeURIComponent(id), { method: 'POST' })
                        .then(r => r.json())
                        .then(data => {
                            if (data && data.success) {
                                btn.closest("tr").remove();
                            } else {
                                alert("No se pudo eliminar el registro: " + (data?.message || "Error desconocido."));
                                btn.disabled = false;
                            }
                        })
                        .catch(() => {
                            alert("Ocurrió un error al intentar eliminar el registro.");
                            btn.disabled = false;
                        });
                });
            });

            // Vaciar todo el historial
            const btnVaciar = document.getElementById("btnVaciarHistorial");
            if (btnVaciar) {
                btnVaciar.addEventListener("click", function () {
                    if (!confirm("¿Vaciar TODO el historial? Se borrarán todos los registros guardados y no se puede deshacer.")) return;

                    btnVaciar.disabled = true;

                    fetch('/Home/VaciarHistorial', { method: 'POST' })
                        .then(r => r.json())
                        .then(data => {
                            if (data && data.success) {
                                window.location.reload();
                            } else {
                                alert("No se pudo vaciar el historial: " + (data?.message || "Error desconocido."));
                                btnVaciar.disabled = false;
                            }
                        })
                        .catch(() => {
                            alert("Ocurrió un error al intentar vaciar el historial.");
                            btnVaciar.disabled = false;
                        });
                });
            }
        });
    </script>
}
