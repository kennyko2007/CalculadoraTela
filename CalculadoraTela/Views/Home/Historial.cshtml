@model IEnumerable<CalculadoraTela.Models.Calculo>

@{
    ViewData["Title"] = "Historial de Cálculos";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-0">Historial de Cálculos Guardados</h3>
            <p class="text-muted small mb-0">Registros almacenados en la base de datos</p>
        </div>
        <a href="/Home/Index" class="btn btn-primary btn-sm rounded-3">
            <i class="bi bi-calculator me-1"></i> Nueva Calculadora
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Fecha (UTC)</th>
                            <th>Resumen Ficha</th>
                            <th class="text-end">Ancho x Lado</th>
                            <th class="text-end">Tejido (U x T)</th>
                            <th class="text-end">Peso Base</th>
                            <th class="text-end">Peso Bolsa</th>
                            <th class="text-end">Producción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.FechaCreacion.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td><span class="badge bg-secondary font-monospace">@item.ResumenFicha</span></td>
                                    <td class="text-end">@item.Ancho.ToString("0.0") x @item.Lado.ToString("0.0")</td>
                                    <td class="text-end">@item.UrdimbreTejido.ToString("0.0") x @item.TramaTejido.ToString("0.0")</td>
                                    <td class="text-end">@item.PesoTejidoBase.ToString("0.0") gm2</td>
                                    <td class="text-end fw-bold text-success">@item.PesoPorBolsa.ToString("0.0") gr</td>
                                    <td class="text-end">@item.ProduccionEstimada.ToString("0.0")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">No hay registros guardados todavía.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
