@model CalculadoraTela.ViewModels.CalculadoraTelaVM

@{
    ViewData["Title"] = "Calculadora de Tela";
}

<!-- Estilos personalizados para diseño oscuro y elegante -->
<style>
    body {
        background-color: #f8fafc;
    }

    .bg-dark-blue {
        background-color: #0f172a !important;
    }

    .btn-dark-blue {
        background-color: #1e3a8a;
        color: #ffffff;
        border: none;
        transition: all 0.2s ease-in-out;
    }

    .btn-dark-blue:hover {
        background-color: #0f172a;
        color: #ffffff;
    }

    .badge-net {
        background-color: #1e40af;
        color: #ffffff;
    }

    .metro-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px dashed #e2e8f0;
    }

    .metro-item:last-child {
        border-bottom: none;
    }

    .metro-label {
        color: #64748b;
        font-weight: 500;
    }

    .metro-value {
        font-weight: 700;
        color: #0f172a;
    }
</style>

<!-- Navbar Superior con Azul Oscuro -->
<nav class="navbar navbar-dark bg-dark-blue shadow-sm mb-4">
    <div class="container-fluid px-4">
        <a class="navbar-brand fw-bold d-flex align-items-center" href="/Home/Index">
            <i class="bi bi-cpu me-2"></i> Calculadora Tela
        </a>
        <div class="d-flex text-white-50 align-items-center gap-3">
            <a href="/Home/Index" class="text-white text-decoration-none small">
                <i class="bi bi-house-door me-1"></i> Calculadora
            </a>
            <a href="/Home/Historial" class="text-white text-decoration-none small">
                <i class="bi bi-clock-history me-1"></i> Historial
            </a>
        </div>
    </div>
</nav>

<div class="container-fluid px-4 pb-5">
    <!-- Encabezado de Página -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="fw-bold text-dark mb-0">
                Calculadora de Tela <span class="badge badge-net fs-6 align-middle">.NET 10</span>
            </h3>
            <p class="text-muted small mb-0">Panel de control de parámetros textiles y métricas de producción</p>
        </div>
        <a href="/Home/Historial" class="btn btn-outline-secondary btn-sm rounded-3">
            <i class="bi bi-clock-history me-1"></i> Ver Historial
        </a>
    </div>

    <!-- Banner Ficha Técnica Limpio -->
    <div class="card bg-dark text-warning border-0 shadow-sm mb-4" style="background-color: #111827 !important;">
        <div class="card-body p-3">
            <span class="badge bg-secondary text-warning mb-2" style="font-size: 0.7rem;">FICHA TÉCNICA GENERADA</span>
            <h4 class="font-monospace fw-bold mb-0 text-warning d-flex flex-wrap gap-3 align-items-center" style="letter-spacing: 0.5px;">
                <span id="lblFichaAnchoLado">@(Model.Ancho.ToString("0.0"))x@(Model.Lado.ToString("0.0"))</span>
                <span id="lblFichaTejido">@(Model.UrdimbreTejido.ToString("0.0"))x@(Model.TramaTejido.ToString("0.0"))</span>
                <span id="lblFichaGm2">@(Model.PesoTejidoBase.ToString("0.0"))gm2</span>
                <span id="lblFichaGmp">@(Model.PesoConRefuerzo.ToString("0.0"))gmp</span>
                <span id="lblFichaGml">@(Model.PesoMetroLineal.ToString("0.0"))gml</span>
                <span id="lblFichaGrBol">@(Model.PesoPorBolsa.ToString("0.0"))gr/Bol</span>
            </h4>
        </div>
    </div>

    <!-- Formulario / Panel principal -->
    <form id="formCalculadora">
        <div class="row g-4">
            <!-- Columna Izquierda: Parámetros -->
            <div class="col-lg-6">
                <!-- 1. Especificaciones de Hilo -->
                <div class="card border-0 shadow-sm rounded-3 mb-3">
                    <div class="card-body">
                        <h6 class="fw-bold text-primary mb-3"><i class="bi bi-diagram-3 me-2"></i>1. Especificaciones de Hilo y Tejido</h6>
                        <div class="row g-3">
                            <div class="col-6">
                                <label class="form-label text-muted small">Urdimbre Tejido</label>
                                <input asp-for="UrdimbreTejido" type="number" step="any" class="form-control calc-trigger">
                            </div>
                            <div class="col-6">
                                <label class="form-label text-muted small">Urdimbre Denier</label>
                                <input asp-for="UrdimbreDenier" type="number" step="any" class="form-control calc-trigger">
                            </div>
                            <div class="col-6">
                                <label class="form-label text-muted small">Trama Tejido</label>
                                <input asp-for="TramaTejido" type="number" step="any" class="form-control calc-trigger">
                            </div>
                            <div class="col-6">
                                <label class="form-label text-muted small">Trama Denier</label>
                                <input asp-for="TramaDenier" type="number" step="any" class="form-control calc-trigger">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 2. Dimensiones y Acabados -->
                <div class="card border-0 shadow-sm rounded-3 mb-3">
                    <div class="card-body">
                        <h6 class="fw-bold text-primary mb-3"><i class="bi bi-aspect-ratio me-2"></i>2. Dimensiones y Acabados</h6>
                        <div class="row g-3">
                            <div class="col-6">
                                <label class="form-label text-muted small">Laminado</label>
                                <input asp-for="Laminado" type="number" step="any" class="form-control calc-trigger">
                            </div>
                            <div class="col-6">
                                <label class="form-label text-muted small">Factor Ancho Refuerzo</label>
                                <input asp-for="AnchoRefuerzoFactor" type="number" step="any" class="form-control calc-trigger">
                            </div>
                            <div class="col-6">
                                <label class="form-label text-muted small">Ancho (cm)</label>
                                <input asp-for="Ancho" type="number" step="any" class="form-control calc-trigger">
                            </div>
                            <div class="col-6">
                                <label class="form-label text-muted small">Lado</label>
                                <input asp-for="Lado" type="number" step="any" class="form-control calc-trigger">
                            </div>
                            <div class="col-6">
                                <label class="form-label text-muted small">Corte</label>
                                <input asp-for="Corte" type="number" step="any" class="form-control calc-trigger">
                            </div>
                            <div class="col-6">
                                <label class="form-label text-muted small">Costura</label>
                                <input asp-for="Costura" type="number" step="any" class="form-control calc-trigger">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 3. Parámetros de Producción -->
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body">
                        <h6 class="fw-bold text-primary mb-3"><i class="bi bi-gear me-2"></i>3. Parámetros de Producción</h6>
                        <div class="row g-3">
                            <div class="col-4">
                                <label class="form-label text-muted small">Número de Máquina</label>
                                <input asp-for="MaquinaNumero" type="number" step="any" class="form-control calc-trigger">
                            </div>
                            <div class="col-4">
                                <label class="form-label text-muted small">Engranaje</label>
                                <input asp-for="Engranaje" type="number" step="any" class="form-control calc-trigger">
                            </div>
                            <div class="col-4">
                                <label class="form-label text-muted small">Horas de Trabajo</label>
                                <input asp-for="Horas" type="number" step="any" class="form-control calc-trigger">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Columna Derecha: Resultados -->
            <div class="col-lg-6">
                <!-- Tabla de Resistencia y Peso -->
                <div class="card border-0 shadow-sm rounded-3 mb-3">
                    <div class="card-body">
                        <h6 class="fw-bold text-success mb-3"><i class="bi bi-check-circle me-2"></i>Resultados de Resistencia y Peso</h6>
                        <table class="table table-borderless align-middle mb-0">
                            <thead>
                                <tr class="text-muted small border-bottom">
                                    <th>Concepto</th>
                                    <th class="text-end">Resistencia</th>
                                    <th class="text-end">Peso</th>
                                    <th class="text-end">%</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="fw-bold">Urdimbre</td>
                                    <td class="text-end" id="resUrdimbre">@Model.ResistenciaUrdimbre.ToString("0.0")</td>
                                    <td class="text-end" id="pesoUrdimbre">@Model.PesoUrdimbre.ToString("0.0")</td>
                                    <td class="text-end"><span class="badge bg-light text-dark border" id="porcUrdimbre">@Model.PorcentajeUrdimbre.ToString("0.0")%</span></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">Trama</td>
                                    <td class="text-end" id="resTrama">@Model.ResistenciaTrama.ToString("0.0")</td>
                                    <td class="text-end" id="pesoTrama">@Model.PesoTrama.ToString("0.0")</td>
                                    <td class="text-end"><span class="badge bg-light text-dark border" id="porcTrama">@Model.PorcentajeTrama.ToString("0.0")%</span></td>
                                </tr>
                                <tr class="border-top">
                                    <td class="fw-bold text-primary">Urdimbre Ref.</td>
                                    <td class="text-end text-primary fw-bold" id="resUrdimbreRef">--</td>
                                    <td class="text-end">-</td>
                                    <td class="text-end">-</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Resumen Metrológico Limpio -->
                <div class="card border-0 shadow-sm rounded-3 mb-3">
                    <div class="card-body">
                        <h6 class="fw-bold text-primary mb-3"><i class="bi bi-box me-2"></i>Resumen Metrológico</h6>
                        
                        <div class="metro-item">
                            <span class="metro-label">Peso Tejido Base</span>
                            <span class="metro-value"><span id="lblPesoBase">@Model.PesoTejidoBase.ToString("0.0")</span> <small class="fw-normal text-muted">gm2</small></span>
                        </div>
                        <div class="metro-item">
                            <span class="metro-label">Peso con Laminado</span>
                            <span class="metro-value"><span id="lblPesoLaminado">@Model.PesoConLaminado.ToString("0.0")</span> <small class="fw-normal text-muted">gm2</small></span>
                        </div>
                        <div class="metro-item">
                            <span class="metro-label">Peso con Refuerzo</span>
                            <span class="metro-value"><span id="lblPesoRefuerzo">@Model.PesoConRefuerzo.ToString("0.0")</span> <small class="fw-normal text-muted">gmp</small></span>
                        </div>
                        <div class="metro-item">
                            <span class="metro-label">Peso Metro Lineal</span>
                            <span class="metro-value"><span id="lblPesoGml">@Model.PesoMetroLineal.ToString("0.0")</span> <small class="fw-normal text-muted">gml</small></span>
                        </div>
                        <div class="metro-item">
                            <span class="metro-label">Peso por Bolsa</span>
                            <span class="metro-value"><span id="lblPesoBolsa">@Model.PesoPorBolsa.ToString("0.0")</span> <small class="fw-normal text-muted">gr/Bol</small></span>
                        </div>
                    </div>
                </div>

                <!-- Producción Estimada -->
                <div class="card text-white border-0 shadow-sm rounded-3 mb-3" style="background-color: #0d9488 !important;">
                    <div class="card-body p-3 d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small text-uppercase opacity-75 fw-bold">Producción Estimada</div>
                            <div class="display-6 fw-bold" id="lblProduccion">@Model.ProduccionEstimada.ToString("0.0")</div>
                        </div>
                        <i class="bi bi-speedometer2 display-4 opacity-50"></i>
                    </div>
                </div>

                <!-- Botón Guardar en Historial -->
                <button type="button" id="btnGuardar" class="btn btn-dark-blue w-100 py-3 rounded-3 fw-bold shadow-sm">
                    <i class="bi bi-bookmark-check me-2"></i> Guardar Registro en Historial
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function f1(val) {
            if (val === null || val === undefined || isNaN(val)) return '--';
            return Number(val).toFixed(1);
        }

        document.querySelectorAll('.calc-trigger').forEach(input => {
            input.addEventListener('input', calcular);
        });

        function calcular() {
            const formData = new FormData(document.getElementById('formCalculadora'));
            const data = Object.fromEntries(formData.entries());

            fetch('/Home/Calcular', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(res => {
                document.getElementById('lblFichaAnchoLado').innerText = `${f1(res.ancho)}x${f1(res.lado)}`;
                document.getElementById('lblFichaTejido').innerText = `${f1(res.urdimbreTejido)}x${f1(res.tramaTejido)}`;
                document.getElementById('lblFichaGm2').innerText = `${f1(res.pesoTejidoBase)}gm2`;
                document.getElementById('lblFichaGmp').innerText = `${f1(res.pesoConRefuerzo)}gmp`;
                document.getElementById('lblFichaGml').innerText = `${f1(res.pesoMetroLineal)}gml`;
                document.getElementById('lblFichaGrBol').innerText = `${f1(res.pesoPorBolsa)}gr/Bol`;

                document.getElementById('resUrdimbre').innerText = f1(res.resistenciaUrdimbre);
                document.getElementById('pesoUrdimbre').innerText = f1(res.pesoUrdimbre);
                document.getElementById('porcUrdimbre').innerText = f1(res.porcentajeUrdimbre) + '%';

                document.getElementById('resTrama').innerText = f1(res.resistenciaTrama);
                document.getElementById('pesoTrama').innerText = f1(res.pesoTrama);
                document.getElementById('porcTrama').innerText = f1(res.porcentajeTrama) + '%';

                document.getElementById('lblPesoBase').innerText = f1(res.pesoTejidoBase);
                document.getElementById('lblPesoLaminado').innerText = f1(res.pesoConLaminado);
                document.getElementById('lblPesoRefuerzo').innerText = f1(res.pesoConRefuerzo);
                document.getElementById('lblPesoGml').innerText = f1(res.pesoMetroLineal);
                document.getElementById('lblPesoBolsa').innerText = f1(res.pesoPorBolsa);

                document.getElementById('lblProduccion').innerText = f1(res.produccionEstimada);
            })
            .catch(err => console.error('Error al calcular:', err));
        }

        document.getElementById('btnGuardar').addEventListener('click', function () {
            const formData = new FormData(document.getElementById('formCalculadora'));
            const data = Object.fromEntries(formData.entries());

            fetch('/Home/GuardarHistorial', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(res => {
                if (res && res.success) {
                    // Redirección forzada y limpia a la pestaña de historial
                    window.location.replace('/Home/Historial');
                } else {
                    alert('Ocurrió un error al guardar el registro.');
                }
            })
            .catch(err => {
                console.error('Error al guardar:', err);
                alert('No se pudo conectar con el servidor.');
            });
        });
    </script>
}
