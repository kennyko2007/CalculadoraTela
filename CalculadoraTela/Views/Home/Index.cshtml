@model CalculadoraTela.ViewModels.CalculadoraTelaVM

@{
    ViewData["Title"] = "Calculadora de Tela";
}

<div class="container-fluid py-4 px-3 px-md-4" style="min-height:100vh;">

    <!-- Encabezado -->
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-4 pb-3 gap-3"
         style="border-bottom:2px solid #d1d9e6;">
        <div class="d-flex align-items-center gap-3">
            <div class="d-flex align-items-center justify-content-center rounded-3 text-white shadow"
                 style="background:linear-gradient(135deg,#1d4ed8,#2563eb); width:52px; height:52px; flex-shrink:0;">
                <i class="bi bi-grid-3x3-gap-fill fs-4"></i>
            </div>
            <div>
                <h2 class="fw-black mb-0" style="color:#0b1629; letter-spacing:-0.5px;">CALCULADORA</h2>
            </div>
        </div>
        <a asp-controller="Home" asp-action="Historial"
           class="btn fw-semibold rounded-pill px-4 py-2 d-flex align-items-center gap-2 w-100 w-md-auto justify-content-center"
           style="background:#fff; border:1.5px solid #c4cfe0; color:#1e293b;">
            <i class="bi bi-clock-history" style="color:#2563eb;"></i> Ver Historial
        </a>
    </div>

    <form id="calcForm">

        <!-- ═══════════════════════════════════════════════════
             SECCIÓN 1: MATRIZ DE CONFIGURACIÓN Y TEJIDO
             ═══════════════════════════════════════════════════ -->
        <div class="card border-0 mb-4 overflow-hidden" style="border-radius:14px; box-shadow:0 2px 12px rgba(0,0,0,0.07);">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center py-3 px-4 gap-2"
                 style="background:linear-gradient(135deg,#060f1e 0%,#0f2040 100%);">
                <span class="fw-bold text-white d-flex align-items-center gap-2" style="letter-spacing:0.6px; font-size:0.92rem;">
                    <i class="bi bi-table" style="color:#60a5fa;"></i>
                    TELA
                </span>
                <div class="d-flex align-items-center gap-2 px-3 py-1 rounded-pill"
                     style="background:rgba(255,255,255,0.10); border:1px solid rgba(255,255,255,0.20);">
                    <label asp-for="TipoProducto" class="small mb-0 fw-semibold" style="color:rgba(255,255,255,0.60);">Tipo Producto:</label>
                    <select asp-for="TipoProducto" id="TipoProducto"
                            class="form-select form-select-sm fw-bold calc-input border-0 shadow-none py-0"
                            style="background:transparent; color:#ffffff; width:110px;">
                        <option value="Plana"   class="bg-dark text-white">Plana</option>
                        <option value="Tubular" class="bg-dark text-white">Tubular</option>
                    </select>
                </div>
            </div>
            <div class="d-md-none text-center small py-2 border-bottom" style="background:#f4f7fb; color:#64748b;">
                <i class="bi bi-arrow-left-right me-1" style="color:#2563eb;"></i>Desliza para ver toda la tabla
            </div>
            <div class="table-responsive bg-white">
                <table class="table table-bordered align-middle text-center mb-0" style="min-width:650px;">
                    <thead>
                        <tr>
                            <th style="width:14%;" class="py-3">ÍTEM</th>
                            <th style="width:16%;" class="py-3">TEJIDO</th>
                            <th style="width:18%;" class="py-3">CINTA</th>
                            <th style="width:16%;" class="py-3">DENIER</th>
                            <th colspan="2" style="width:36%;" class="py-3">OTROS</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Urdimbre -->
                        <tr>
                            <td class="fw-bold fila-label">Urdimbre</td>
                            <td><input asp-for="UrdimbreTejido" class="form-control form-control-sm text-center calc-input fw-bold" type="number" inputmode="decimal" step="0.1" /></td>
                            <td>
                                <div class="input-group input-group-sm">
                                    <input asp-for="CintaUrdimbre" class="form-control text-center calc-input fw-bold" type="number" inputmode="decimal" step="0.1" />
                                    <span class="input-group-text">mm</span>
                                </div>
                            </td>
                            <td><input asp-for="UrdimbreDenier" class="form-control form-control-sm text-center calc-input fw-bold" type="number" inputmode="numeric" step="1" /></td>
                            <td class="fw-semibold text-end pe-2 fila-label" style="width:1%; white-space:nowrap;">Ancho</td>
                            <td>
                                <div class="input-group input-group-sm">
                                    <input asp-for="Ancho" id="Ancho" class="form-control text-center calc-input fw-bold" type="number" inputmode="decimal" step="0.1" />
                                    <span class="input-group-text">cm</span>
                                </div>
                            </td>
                        </tr>
                        <!-- Trama -->
                        <tr>
                            <td class="fw-bold fila-label">Trama</td>
                            <td><input asp-for="TramaTejido" class="form-control form-control-sm text-center calc-input fw-bold" type="number" inputmode="decimal" step="0.1" /></td>
                            <td>
                                <div class="input-group input-group-sm">
                                    <input asp-for="CintaTrama" class="form-control text-center calc-input fw-bold" type="number" inputmode="decimal" step="0.1" />
                                    <span class="input-group-text">mm</span>
                                </div>
                            </td>
                            <td><input asp-for="TramaDenier" class="form-control form-control-sm text-center calc-input fw-bold" type="number" inputmode="numeric" step="1" /></td>
                            <td class="fw-semibold text-end pe-2 fila-label" style="white-space:nowrap;">Laminado</td>
                            <td>
                                <div class="input-group input-group-sm">
                                    <input asp-for="Laminado" class="form-control text-center calc-input fw-bold" type="number" inputmode="decimal" step="0.1" />
                                    <span class="input-group-text">gm2</span>
                                </div>
                            </td>
                        </tr>
                        <!-- Refuerzo -->
                        <tr>
                            <td class="fw-bold fila-label-refuerzo">Refuerzo</td>
                            <td>
                                <input asp-for="UrdimbreRefuerzoTejido" id="UrdimbreRefuerzoTejido"
                                       class="form-control form-control-sm text-center fw-bold calc-input"
                                       type="number" step="0.1" readonly tabindex="-1"
                                       style="background:#eff6ff; color:#1d4ed8;" />
                            </td>
                            <td>
                                <div class="input-group input-group-sm">
                                    <input asp-for="CintaRefuerzo" class="form-control text-center calc-input fw-bold" type="number" inputmode="decimal" step="0.1" />
                                    <span class="input-group-text">mm</span>
                                </div>
                            </td>
                            <td>
                                <input asp-for="DenierRefuerzo" id="DenierRefuerzo"
                                       class="form-control form-control-sm text-center calc-input fw-bold"
                                       type="number" step="1" readonly tabindex="-1"
                                       style="background:#eff6ff; color:#1d4ed8;" />
                            </td>
                            <td class="fw-semibold text-end pe-2 fila-label-refuerzo" style="white-space:nowrap;">Ancho Ref.</td>
                            <td>
                                <div class="input-group input-group-sm">
                                    <input asp-for="AnchoRefuerzoFactor" class="form-control text-center calc-input fw-bold" type="number" inputmode="numeric" min="0" max="12" step="1" />
                                    <span class="input-group-text">cm</span>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════
             SECCIÓN 2: RESULTADOS — 3 BLOQUES + PESO TOTAL
             ═══════════════════════════════════════════════════ -->
        <div class="results-block mb-4">

            <!-- Cabecera general -->
            <div class="results-header">
                <i class="bi bi-bar-chart-line-fill" style="color:#fbbf24; font-size:1.1rem;"></i>
                RESULTADOS 
                <i class="bi bi-bar-chart-line-fill" style="color:#fbbf24; font-size:1.1rem;"></i>
            </div>

            <!-- ── Cuatro bloques en fila ───────────────────────── -->
            <div class="row g-0 results-blocks-row">

                <!-- BLOQUE: DATOS -->
                <div class="col-12 col-md-3 res-block res-block-datos">
                    <div class="res-block-header">
                        <i class="bi bi-list-ul me-1" style="color:#94a3b8;"></i> DATOS
                    </div>
                    <div class="res-block-body">
                        <div class="res-data-row">
                            <span class="res-data-label">Producto</span>
                            <span class="res-data-value" id="lblTipoProductoRes">@Model.TipoProducto</span>
                        </div>
                        <div class="res-data-row">
                            <span class="res-data-label">Medida</span>
                            <span class="res-data-value" id="resMedida">@Model.Ancho x @Model.Corte</span>
                        </div>
                        <div class="res-data-row">
                            <span class="res-data-label">Tejido</span>
                            <span class="res-data-value" id="resTejidoConcatenado">@Model.UrdimbreTejido x @Model.TramaTejido</span>
                        </div>
                        <div class="res-data-row">
                            <span class="res-data-label">Denier</span>
                            <span class="res-data-value" id="resDenierConcatenado">@Model.UrdimbreDenier x @Model.TramaDenier</span>
                        </div>
                        <div class="res-data-row">
                            <span class="res-data-label">Conos</span>
                            <span class="res-data-value" id="resCantidadConos">@Model.MaquinaNumero <span class="res-data-unit">conos</span></span>
                        </div>
                    </div>
                </div>

                <!-- BLOQUE: RESISTENCIA -->
                <div class="col-12 col-md-3 res-block res-block-resistencia">
                    <div class="res-block-header">
                        <i class="bi bi-lightning-charge-fill me-1" style="color:#60a5fa;"></i> RESISTENCIA
                    </div>
                    <div class="res-block-body">
                        <div class="res-metric-row">
                            <span class="res-metric-label">Urdimbre</span>
                            <div class="res-metric-value-wrap">
                                <span class="res-resistance" id="resUrdimbreRes2">@Model.ResistenciaUrdimbre.ToString("F2")</span>
                                <span class="res-unit">KgF</span>
                            </div>
                        </div>
                        <div class="res-metric-row">
                            <span class="res-metric-label">Trama</span>
                            <div class="res-metric-value-wrap">
                                <span class="res-resistance" id="resTramaRes2">@Model.ResistenciaTrama.ToString("F2")</span>
                                <span class="res-unit">KgF</span>
                            </div>
                        </div>
                        <div class="res-metric-row res-metric-row-refuerzo">
                            <span class="res-metric-label res-metric-label-refuerzo">Refuerzo</span>
                            <div class="res-metric-value-wrap">
                                <span class="res-refuerzo-val" id="resUrdRefRes2">@Model.UrdimbreRefuerzoResistencia.ToString("F2")</span>
                                <span class="res-unit res-unit-green">KgF</span>
                            </div>
                            <div class="res-metric-sub" id="resAnchoRefuerzoLabel">Ancho: @Model.AnchoRefuerzoFactor cm</div>
                        </div>
                    </div>
                </div>

                <!-- BLOQUE: PESO -->
                <div class="col-12 col-md-3 res-block res-block-peso">
                    <div class="res-block-header">
                        <i class="bi bi-speedometer2 me-1" style="color:#6ee7b7;"></i> PESO
                    </div>
                    <div class="res-block-body">
                        <div class="res-metric-row">
                            <span class="res-metric-label">Urdimbre</span>
                            <div class="res-metric-value-wrap">
                                <span class="res-peso-val" id="resPesoUrdimbreTipo">@Model.PesoUrdimbre.ToString("F2")</span>
                                <span class="res-unit">gr</span>
                                <span class="res-badge ms-2" id="resUrdimbrePorc2">@Model.PorcentajeUrdimbre.ToString("F1") %</span>
                            </div>
                        </div>
                        <div class="res-metric-row">
                            <span class="res-metric-label">Trama</span>
                            <div class="res-metric-value-wrap">
                                <span class="res-peso-val" id="resPesoTramaTipo">@Model.PesoTrama.ToString("F2")</span>
                                <span class="res-unit">gr</span>
                                <span class="res-badge ms-2" id="resTramaPorc2">@Model.PorcentajeTrama.ToString("F1") %</span>
                            </div>
                        </div>
                        <div class="res-metric-row res-metric-row-refuerzo">
                            <span class="res-metric-label res-metric-label-refuerzo">Refuerzo</span>
                            <div class="res-metric-value-wrap">
                                <span class="res-refuerzo-peso" id="resPesoRefuerzoTipo">@Model.PesoRefuerzo.ToString("F2")</span>
                                <span class="res-unit res-unit-green">gr</span>
                                <span class="res-badge-green ms-2" id="resPorcRefuerzo">100 %</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- BLOQUE: PESO TOTAL -->
                <div class="col-12 col-md-3 res-block res-block-peso-total">
                    <div class="res-block-header" style="background:linear-gradient(135deg,#060f1e 0%,#0f2040 100%); color:#fff; border-bottom:2px solid #2563eb;">
                        <i class="bi bi-layers-fill me-1" style="color:#fbbf24;"></i> PESO TOTAL
                    </div>
                    <div class="res-block-body">
                        <!-- gm2 base -->
                        <div class="res-metric-row">
                            <span class="res-metric-label" style="font-size:0.63rem;">gm2 <span style="font-weight:500; text-transform:none;">(pp base)</span></span>
                            <div class="res-metric-value-wrap">
                                <span class="weight-value-gm2 d-inline-block px-2 rounded" style="font-size:1.45rem;" id="resPesoBase">@Model.PesoTejidoBase.ToString("F1")</span>
                            </div>
                        </div>
                        <!-- gm2 laminado -->
                        <div class="res-metric-row">
                            <span class="res-metric-label" style="font-size:0.63rem;">gm2 <span style="font-weight:500; text-transform:none;">(pp + lam)</span></span>
                            <div class="res-metric-value-wrap">
                                <span class="weight-value-lam d-inline-block px-2 rounded" style="font-size:1.45rem;" id="resPesoLaminado">@Model.PesoConLaminado.ToString("F1")</span>
                            </div>
                        </div>
                        <!-- gmp -->
                        <div class="res-metric-row">
                            <span class="res-metric-label" style="font-size:0.63rem;">gmp</span>
                            <div class="res-metric-value-wrap">
                                <span class="weight-value-gmp d-inline-block px-2 rounded" style="font-size:1.45rem;" id="resGmp">@Model.PesoConRefuerzo.ToString("F1")</span>
                            </div>
                        </div>
                        <!-- gml -->
                        <div class="res-metric-row gml-value-cell" style="flex-direction:column; align-items:center; justify-content:center; padding:14px 18px;">
                            <span class="res-metric-label gml-row-label" style="font-size:0.63rem; background:none; border:none; padding:0; color:#92400e;">gml</span>
                            <div class="res-metric-value-wrap mt-1">
                                <span id="resPesoMetro">@Model.PesoMetroLineal.ToString("F1")</span>
                                <span class="gml-unit">gml</span>
                            </div>
                        </div>
                    </div>
                </div>

            </div><!-- /row -->

        </div><!-- /results-block -->

        <!-- Botón Guardar -->
        <div class="row mb-2">
            <div class="col-12">
                <button type="button" id="btnGuardar"
                        class="btn w-100 fw-bold text-uppercase text-white border-0 d-flex align-items-center justify-content-center gap-2"
                        style="letter-spacing:0.8px;">
                    <i class="bi bi-bookmark-check-fill fs-5" style="color:#fbbf24;"></i>
                    GUARDAR REGISTRO EN HISTORIAL
                </button>
            </div>
        </div>

    </form>
</div>

@section Scripts {
    <script src="~/js/calculadora.js"></script>
}
