@model CalculadoraTela.ViewModels.CalculadoraTelaVM

@{
    ViewData["Title"] = "Calculadora de Tela - Ficha Técnica";
}

<div class="container-fluid px-4 pb-5">
    <div class="row g-4">
        
        <!-- ==========================================
             COLUMNA IZQUIERDA: FORMULARIO DE ENTRADA
             ========================================== -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white py-3 border-bottom">
                    <h5 class="fw-bold text-dark mb-0">
                        <i class="bi bi-sliders me-2 text-primary"></i>Parámetros de la Tela
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form id="formCalculo" onsubmit="procesarCalculo(event)">
                        
                        <!-- 1. Tejido Urdimbre y Trama -->
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-secondary">Urdimbre Tejido</label>
                                <input type="number" step="0.1" class="form-control" name="UrdimbreTejido" value="@Model.UrdimbreTejido" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-secondary">Trama Tejido</label>
                                <input type="number" step="0.1" class="form-control" name="TramaTejido" value="@Model.TramaTejido" required>
                            </div>
                        </div>

                        <!-- 2. Denier -->
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-secondary">Urdimbre Denier</label>
                                <input type="number" class="form-control" name="UrdimbreDenier" value="@Model.UrdimbreDenier" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-secondary">Trama Denier</label>
                                <input type="number" class="form-control" name="TramaDenier" value="@Model.TramaDenier" required>
                            </div>
                        </div>

                        <!-- 3. Dimensiones del Producto -->
                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-secondary">Ancho (cm)</label>
                                <input type="number" step="0.1" class="form-control" name="Ancho" value="@Model.Ancho" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-secondary">Corte (cm)</label>
                                <input type="number" step="0.1" class="form-control" name="Corte" value="@Model.Corte">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-secondary">Costura (cm)</label>
                                <input type="number" step="0.1" class="form-control" name="Costura" value="@Model.Costura">
                            </div>
                        </div>

                        <!-- 4. Laminado y Refuerzos -->
                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-secondary">Laminado</label>
                                <input type="number" step="0.1" class="form-control" name="Laminado" value="@Model.Laminado">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-secondary">Factor Refuerzo</label>
                                <input type="number" step="0.01" class="form-control" name="AnchoRefuerzoFactor" value="@Model.AnchoRefuerzoFactor">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-secondary">Lado / Caras</label>
                                <input type="number" step="0.1" class="form-control" name="Lado" value="@Model.Lado">
                            </div>
                        </div>

                        <!-- 5. Parámetros de Máquina -->
                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-secondary">Máquina N°</label>
                                <input type="number" class="form-control" name="MaquinaNumero" value="@Model.MaquinaNumero" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-secondary">Engranaje</label>
                                <input type="number" step="0.01" class="form-control" name="Engranaje" value="@Model.Engranaje" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-secondary">Horas Proyectadas</label>
                                <input type="number" step="0.1" class="form-control" name="Horas" value="@Model.Horas" required>
                            </div>
                        </div>

                        <!-- Botón de Acción Principal -->
                        <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm">
                            <i class="bi bi-calculator me-2"></i> Calcular Ficha Técnica
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- ==========================================
             COLUMNA DERECHA: CUADRO VERDE DE RESULTADOS
             ========================================== -->
        <div class="col-lg-5">
            <div id="cuadroResultadoVerde" class="card border-0 shadow text-white rounded-3 bg-success bg-gradient p-4 sticky-top" style="top: 20px;">
                
                <!-- Encabezado del Cuadro Verde -->
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">
                        <i class="bi bi-check-circle-fill me-2"></i> Ficha Técnica Generada
                    </h5>
                    <span class="badge bg-light text-success fw-bold px-3 py-2 rounded-pill">Sincronizado</span>
                </div>

                <hr class="border-light opacity-25 my-2">

                <!-- Resumen en Formato Cadena Concatenada (A11 de Excel) -->
                <div class="p-3 rounded bg-black bg-opacity-20 font-monospace small mb-3 text-center border border-light border-opacity-10">
                    <span class="d-block text-white-50 small mb-1">CÓDIGO DE FICHA TÉCNICA</span>
                    <strong class="fs-6 text-warning" id="lblResumenFicha">
                        @(string.IsNullOrEmpty(Model.ResumenFicha) ? "90x0 \\ 13x11 \\ 0gm2 \\ 0gmp \\ 0gml \\ 0gr/Bol." : Model.ResumenFicha)
                    </strong>
                </div>

                <!-- Tarjetas de Resultados Clave -->
                <div class="row g-3 text-center my-1">
                    
                    <!-- Peso Metro Lineal (H7) -->
                    <div class="col-6">
                        <div class="p-3 bg-white bg-opacity-10 rounded border border-light border-opacity-25">
                            <small class="d-block text-white-50 text-uppercase fw-semibold" style="font-size: 0.75rem;">Peso Metro Lineal</small>
                            <span class="fs-3 fw-bold" id="lblPesoMetro">@Model.PesoMetroLineal.ToString("0.00")</span>
                            <small class="d-inline text-white-50">gml</small>
                        </div>
                    </div>

                    <!-- Peso por Bolsa (H9) -->
                    <div class="col-6">
                        <div class="p-3 bg-white bg-opacity-10 rounded border border-light border-opacity-25">
                            <small class="d-block text-white-50 text-uppercase fw-semibold" style="font-size: 0.75rem;">Peso por Bolsa</small>
                            <span class="fs-3 fw-bold" id="lblPesoBolsa">@Model.PesoPorBolsa.ToString("0.00")</span>
                            <small class="d-inline text-white-50">gr</small>
                        </div>
                    </div>

                    <!-- Producción Estimada (E13) -->
                    <div class="col-12">
                        <div class="p-3 bg-white bg-opacity-10 rounded border border-light border-opacity-25">
                            <small class="d-block text-white-50 text-uppercase fw-semibold" style="font-size: 0.75rem;">Producción Estimada</small>
                            <span class="fs-2 fw-bold text-warning" id="lblProduccion">@Model.ProduccionEstimada.ToString("0.00")</span>
                            <small class="fs-5 text-white">metros</small>
                        </div>
                    </div>

                    <!-- Datos Complementarios (gm2 y gmp) -->
                    <div class="col-6">
                        <div class="p-2 bg-black bg-opacity-10 rounded">
                            <small class="text-white-50 d-block">Peso Con Laminado</small>
                            <strong id="lblPesoLaminado">@Model.PesoConLaminado.ToString("0.00")</strong> <small>gm2</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-2 bg-black bg-opacity-10 rounded">
                            <small class="text-white-50 d-block">Peso Con Refuerzo</small>
                            <strong id="lblPesoRefuerzo">@Model.PesoConRefuerzo.ToString("0.00")</strong> <small>gmp</small>
                        </div>
                    </div>
                </div>

                <!-- Pie de tarjeta con estatus de base de datos -->
                <div class="mt-4 pt-2 small text-white-50 text-center border-top border-light border-opacity-10">
                    <i class="bi bi-database-check me-1"></i> Cálculo procesado y respaldado en PostgreSQL.
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function procesarCalculo(e) {
            e.preventDefault();
            
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());

            // Convertir campos numéricos de texto a float/int para C#
            for (let key in data) {
                if (data[key] !== "") {
                    data[key] = parseFloat(data[key]);
                }
            }

            fetch('/Home/Calcular', {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json' 
                },
                body: JSON.stringify(data)
            })
            .then(res => {
                if (!res.ok) throw new Error("Error en el servidor al calcular");
                return res.json();
            })
            .then(res => {
                // Actualizar los elementos dentro del Cuadro Verde
                document.getElementById('lblResumenFicha').innerText = res.resumenFicha || '--';
                document.getElementById('lblPesoMetro').innerText = res.pesoMetroLineal.toFixed(2);
                document.getElementById('lblPesoBolsa').innerText = res.pesoPorBolsa.toFixed(2);
                document.getElementById('lblProduccion').innerText = res.produccionEstimada.toFixed(2);
                document.getElementById('lblPesoLaminado').innerText = res.pesoConLaminado.toFixed(2);
                document.getElementById('lblPesoRefuerzo').innerText = res.pesoConRefuerzo.toFixed(2);
            })
            .catch(err => {
                console.error("Error al procesar el cálculo:", err);
                alert("Ocurrió un error al realizar el cálculo. Revisa la consola.");
            });
        }
    </script>
}
