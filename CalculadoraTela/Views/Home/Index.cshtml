@model CalculadoraTela.ViewModels.CalculadoraTelaVM

@{
    ViewData["Title"] = "Calculadora de Tela";
}

<div class="container py-4">
    <!-- Encabezado de la App -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="bi bi-cpu text-primary me-2"></i>Calculadora de Tela
                <span class="badge bg-primary fs-6 fw-normal">.NET 10</span>
            </h2>
            <p class="text-muted mb-0">Panel de control de parámetros textiles y métricas de producción</p>
        </div>
        <div>
            <a asp-controller="Home" asp-action="Historial" class="btn btn-outline-secondary shadow-sm">
                <i class="bi bi-clock-history me-1"></i> Ver Historial
            </a>
        </div>
    </div>

    <!-- Ficha Técnica Resumen (Hero Card) -->
    <div class="card hero-card mb-4">
        <div class="card-body p-4">
            <div class="d-flex align-items-center mb-2">
                <span class="badge-a11 text-uppercase fw-semibold">
                    <i class="bi bi-file-earmark-text me-1"></i> Ficha Técnica Generada (Celda A11)
                </span>
            </div>
            <div class="ficha-text text-warning mt-2 fw-bold" id="txtResumenFicha">
                @Model.ResumenFicha
            </div>
        </div>
    </div>

    <form id="calcForm">
        <div class="row g-4">
            <!-- COLUMNA IZQUIERDA: FORMULARIOS DE ENTRADA -->
            <div class="col-lg-6">

                <!-- Card 0: Configuración del Producto -->
                <div class="card card-custom mb-4">
                    <div class="card-header-custom d-flex align-items-center">
                        <i class="bi bi-sliders text-secondary me-2 fs-5"></i> Configuración del Producto
                    </div>
                    <div class="card-body p-4">
                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="TipoProducto" class="form-label text-secondary small fw-semibold"></label>
                                <select asp-for="TipoProducto" class="form-select form-control-custom calc-input" id="TipoProducto">
                                    <option value="Tubular">Tubular</option>
                                    <option value="Plana">Plana</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Card 1: Hilos -->
                <div class="card card-custom mb-4">
                    <div class="card-header-custom d-flex align-items-center">
                        <i class="bi bi-diagram-3 text-primary me-2 fs-5"></i> 1. Especificaciones de Hilo y Tejido
                    </div>
                    <div class="card-body p-4">
                        <div class="row g-3">
                            <div class="col-6">
                                <label asp-for="UrdimbreTejido" class="form-label text-secondary small fw-semibold"></label>
                                <input asp-for="UrdimbreTejido" class="form-control form-control-custom calc-input" type="number" step="0.1" />
                            </div>
                            <div class="col-6">
                                <label asp-for="UrdimbreDenier" class="form-label text-secondary small fw-semibold"></label>
                                <input asp-for="UrdimbreDenier" class="form-control form-control-custom calc-input" type="number" step="1" />
                            </div>
                            <div class="col-6">
                                <label asp-for="TramaTejido" class="form-label text-secondary small fw-semibold"></label>
                                <input asp-for="TramaTejido" class="form-control form-control-custom calc-input" type="number" step="0.1" />
                            </div>
                            <div class="col-6">
                                <label asp-for="TramaDenier" class="form-label text-secondary small fw-semibold"></label>
                                <input asp-for="TramaDenier" class="form-control form-control-custom calc-input" type="number" step="1" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Card 2: Acabados -->
                <div class="card card-custom mb-4">
                    <div class="card-header-custom d-flex align-items-center">
                        <i class="bi bi-aspect-ratio text-info me-2 fs-5"></i> 2. Dimensiones y Acabados
                    </div>
                    <div class="card-body p-4">
                        <div class="row g-3">
                            <div class="col-6">
                                <label asp-for="Laminado" class="form-label text-secondary small fw-semibold"></label>
                                <input asp-for="Laminado" class="form-control form-control-custom calc-input" type="number" step="0.1" />
                            </div>
                            <div class="col-6">
                                <label asp-for="AnchoRefuerzoFactor" class="form-label text-secondary small fw-semibold"></label>
                                <input asp-for="AnchoRefuerzoFactor" class="form-control form-control-custom calc-input" type="number" step="0.01" />
                            </div>
                            <div class="col-6">
                                <label asp-for="Ancho" class="form-label text-secondary small fw-semibold"></label>
                                <input asp-for="Ancho" class="form-control form-control-custom calc-input" type="number" step="1" />
                            </div>
                            <div class="col-6">
                                <label asp-for="Lado" class="form-label text-secondary small fw-semibold"></label>
                                <input asp-for="Lado" class="form-control form-control-custom calc-input" type="number" step="1" />
                            </div>
                            <div class="col-6">
                                <label asp-for="Corte" class="form-label text-secondary small fw-semibold"></label>
                                <input asp-for="Corte" class="form-control form-control-custom calc-input" type="number" step="0.1" />
                            </div>
                            <div class="col-6">
                                <label asp-for="Costura" class="form-label text-secondary small fw-semibold"></label>
                                <input asp-for="Costura" class="form-control form-control-custom calc-input" type="number" step="0.1" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Card 3: Producción (Ahora correctamente dentro de la columna izquierda) -->
                <div class="card card-custom mb-4">
                    <div class="card-header-custom d-flex align-items-center">
                        <i class="bi bi-gear-wide-connected text-warning me-2 fs-5"></i> 3. Parámetros de Producción
                    </div>
                    <div class="card-body p-4">
                        <div class="row g-3">
                            <div class="col-4">
                                <label asp-for="MaquinaNumero" class="form-label text-secondary small fw-semibold"></label>
                                <input asp-for="MaquinaNumero" class="form-control form-control-custom calc-input" type="number" min="1" max="20" />
                            </div>
                            <div class="col-4">
                                <label asp-for="Engranaje" class="form-label text-secondary small fw-semibold"></label>
                                <input asp-for="Engranaje" class="form-control form-control-custom calc-input" type="number" step="0.1" />
                            </div>
                            <div class="col-4">
                                <label asp-for="Horas" class="form-label text-secondary small fw-semibold"></label>
                                <input asp-for="Horas" class="form-control form-control-custom calc-input" type="number" step="0.5" />
                            </div>
                        </div>
                    </div>
                </div>

            </div> <!-- Fin Columna Izquierda -->

            <!-- COLUMNA DERECHA: RESULTADOS -->
            <div class="col-lg-6">

                <!-- Tabla de Resistencia -->
                <div class="card card-custom mb-4">
                    <div class="card-header-custom d-flex align-items-center">
                        <i class="bi bi-shield-check text-success me-2 fs-5"></i> Resultados de Resistencia y Peso
                    </div>
                    <div class="card-body p-3">
                        <table class="table table-custom text-center align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Concepto</th>
                                    <th>Resistencia</th>
                                    <th>Peso</th>
                                    <th>%</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <th class="text-start ps-3">Urdimbre</th>
                                    <td id="resUrdimbreRes" class="fw-semibold">@Model.ResistenciaUrdimbre.ToString("F2")</td>
                                    <td id="resUrdimbrePeso">@Model.PesoUrdimbre.ToString("F2")</td>
                                    <td><span class="badge bg-light text-dark border" id="resUrdimbrePorc">@Model.PorcentajeUrdimbre.ToString("F2")%</span></td>
                                </tr>
                                <tr>
                                    <th class="text-start ps-3">Trama</th>
                                    <td id="resTramaRes" class="fw-semibold">@Model.ResistenciaTrama.ToString("F2")</td>
                                    <td id="resTramaPeso">@Model.PesoTrama.ToString("F2")</td>
                                    <td><span class="badge bg-light text-dark border" id="resTramaPorc">@Model.PorcentajeTrama.ToString("F2")%</span></td>
                                </tr>
                                <tr class="table-light">
                                    <th class="text-start ps-3">Urdimbre Ref.</th>
                                    <td id="resUrdRefRes" class="fw-semibold text-primary">@Model.UrdimbreRefuerzoResistencia.ToString("F2")</td>
                                    <td colspan="2" class="text-muted small">-</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Resumen Metrológico -->
                <div class="card card-custom mb-4">
                    <div class="card-header-custom d-flex align-items-center">
                        <i class="bi bi-box-seam text-primary me-2 fs-5"></i> Resumen Metrológico
                    </div>
                    <div class="card-body p-3">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item d-flex justify-content-between align-items-center py-2 border-0">
                                <span class="text-secondary">Peso Tejido Base (G2):</span>
                                <strong id="resPesoBase">@Model.PesoTejidoBase.ToString("F2")</strong>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center py-2 border-0 bg-light rounded-2">
                                <span class="text-secondary">Peso con Laminado (G4 - gm2):</span>
                                <strong id="resPesoLaminado">@Model.PesoConLaminado.ToString("F2")</strong>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center py-2 border-0">
                                <span class="text-secondary">Peso con Refuerzo (G5 - gmp):</span>
                                <strong id="resPesoRefuerzo">@Model.PesoConRefuerzo.ToString("F2")</strong>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center py-2 border-0 bg-light rounded-2">
                                <span class="text-secondary">Peso Metro Lineal (G7 - gml):</span>
                                <strong id="resPesoMetro">@Model.PesoMetroLineal.ToString("F2")</strong>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center py-2 border-0">
                                <span class="text-secondary">Peso por Bolsa (G9 - gr/Bol):</span>
                                <strong id="resPesoBolsa">@Model.PesoPorBolsa.ToString("F2")</strong>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- KPI Destacado: Producción -->
                <div class="kpi-card shadow-sm mb-4 d-flex justify-content-between align-items-center">
                    <div>
                        <small class="text-uppercase fw-semibold text-white-50">Producción Estimada (D13)</small>
                        <h2 class="mb-0 fw-bold mt-1" id="resProduccion">@Model.ProduccionEstimada.ToString("F2")</h2>
                    </div>
                    <div class="fs-1 text-white-50">
                        <i class="bi bi-speedometer2"></i>
                    </div>
                </div>

                <!-- Botón Guardar -->
                <button type="button" id="btnGuardar" class="btn btn-primary btn-guardar w-100 text-white shadow-lg">
                    <i class="bi bi-bookmark-check me-2"></i> Guardar Registro en Historial
                </button>

            </div> <!-- Fin Columna Derecha -->
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/calculadora.js"></script>
}
