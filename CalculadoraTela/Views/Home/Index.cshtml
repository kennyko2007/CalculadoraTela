@model CalculadoraTela.ViewModels.CalculadoraTelaVM

@{
    ViewData["Title"] = "Calculadora de Tela";
}

<div class="container-fluid py-4 px-3 px-md-4" style="background-color: #f8fafc; min-height: 100vh;">
    <!-- Encabezado -->
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-4 pb-3 border-bottom border-2 gap-3">
        <h2 class="fw-bold mb-0" style="color: #0f172a;">
            <i class="bi bi-file-earmark-spreadsheet text-primary me-2"></i>TELA 
        </h2>
        <a asp-controller="Home" asp-action="Historial" class="btn btn-outline-primary shadow-sm px-4 fw-semibold w-100 w-md-auto text-center">
            <i class="bi bi-clock-history me-1"></i> Ver Historial
        </a>
    </div>

    <form id="calcForm">
        <!-- MATRIZ DE CONFIGURACIÓN Y TEJIDO -->
        <div class="card shadow-sm mb-4 border-0 rounded-3 overflow-hidden">
            <div class="card-header text-white fw-bold d-flex flex-column flex-md-row justify-content-between align-items-md-center py-3 px-3 px-md-4 gap-2" style="background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%);">
                <span><i class="bi bi-table me-2"></i> MATRIZ DE CONFIGURACIÓN Y TEJIDO</span>
                <div class="d-flex align-items-center gap-2">
                    <label asp-for="TipoProducto" class="text-white-50 small mb-0 fw-semibold">Tipo Producto:</label>
                    <select asp-for="TipoProducto" class="form-select form-select-sm text-dark fw-bold calc-input shadow-none border-0" id="TipoProducto" style="width: 140px;">
                        <option value="Plana">Plana</option>
                        <option value="Tubular">Tubular</option>
                    </select>
                </div>
            </div>
            <div class="card-body p-0 table-responsive bg-white">
                <table class="table table-bordered align-middle text-center mb-0 border-light" style="min-width: 650px;">
                    <thead class="text-secondary uppercase fs-7" style="background-color: #f1f5f9;">
                        <tr>
                            <th style="width: 14%;" class="py-3">ITEM</th>
                            <th style="width: 14%;" class="py-3">TEJIDO</th>
                            <th style="width: 14%;" class="py-3">CINTA</th>
                            <th style="width: 14%;" class="py-3">DENIER</th>
                            <th style="width: 16%;" class="py-3">RESISTENCIA</th>
                            <th colspan="2" style="width: 28%;" class="py-3">PESO</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Fila 1: URDIMBRE -->
                        <tr>
                            <td class="fw-bold text-secondary bg-light">URDIMBRE</td>
                            <td><input asp-for="UrdimbreTejido" class="form-control form-control-sm text-center calc-input fw-bold shadow-none" type="number" step="0.1" /></td>
                            <td>
                                <div class="input-group input-group-sm">
                                    <input asp-for="CintaUrdimbre" class="form-control text-center calc-input fw-bold shadow-none" type="number" step="0.1" />
                                    <span class="input-group-text bg-light text-muted small">mm</span>
                                </div>
                            </td>
                            <td><input asp-for="UrdimbreDenier" class="form-control form-control-sm text-center calc-input fw-bold shadow-none" type="number" step="1" /></td>
                            <td><span id="resUrdimbreRes" class="fw-bold text-primary">@Model.ResistenciaUrdimbre.ToString("F2") KgF</span></td>
                            <td><span id="resUrdimbrePeso" class="text-secondary">@Model.PesoUrdimbre.ToString("F2") gr</span></td>
                            <td><span id="resUrdimbrePorc" class="badge rounded-pill bg-light text-dark border px-2 py-1">@Model.PorcentajeUrdimbre.ToString("F1") %</span></td>
                        </tr>
                        <!-- Fila 2: TRAMA -->
                        <tr>
                            <td class="fw-bold text-secondary bg-light">TRAMA</td>
                            <td><input asp-for="TramaTejido" class="form-control form-control-sm text-center calc-input fw-bold shadow-none" type="number" step="0.1" /></td>
                            <td>
                                <div class="input-group input-group-sm">
                                    <input asp-for="CintaTrama" class="form-control text-center calc-input fw-bold shadow-none" type="number" step="0.1" />
                                    <span class="input-group-text bg-light text-muted small">mm</span>
                                </div>
                            </td>
                            <td><input asp-for="TramaDenier" class="form-control form-control-sm text-center calc-input fw-bold shadow-none" type="number" step="1" /></td>
                            <td><span id="resTramaRes" class="fw-bold text-primary">@Model.ResistenciaTrama.ToString("F2") KgF</span></td>
                            <td><span id="resTramaPeso" class="text-secondary">@Model.PesoTrama.ToString("F2") gr</span></td>
                            <td><span id="resTramaPorc" class="badge rounded-pill bg-light text-dark border px-2 py-1">@Model.PorcentajeTrama.ToString("F1") %</span></td>
                        </tr>
                        <!-- Fila 3: URDIMBRE REFUERZO -->
                        <tr style="background-color: #f8fafc;">
                            <td class="fw-bold text-primary">URDIMBRE REF.</td>
                            <td><input asp-for="UrdimbreRefuerzoTejido" class="form-control form-control-sm text-center calc-input fw-bold shadow-none" type="number" step="0.1" /></td>
                            <td>
                                <div class="input-group input-group-sm">
                                    <input asp-for="CintaRefuerzo" class="form-control text-center calc-input fw-bold shadow-none" type="number" step="0.1" />
                                    <span class="input-group-text bg-light text-muted small">mm</span>
                                </div>
                            </td>
                            <td><input asp-for="DenierRefuerzo" class="form-control form-control-sm text-center calc-input fw-bold shadow-none" type="number" step="1" /></td>
                            <td><span id="resUrdRefRes" class="fw-bold text-primary">@Model.UrdimbreRefuerzoResistencia.ToString("F2") KgF</span></td>
                            <td class="fw-semibold text-secondary text-start ps-2">ANCHO REFUERZO</td>
                            <td>
                                <div class="input-group input-group-sm">
                                    <input asp-for="AnchoRefuerzoFactor" class="form-control text-center calc-input fw-bold shadow-none" type="number" min="0" max="12" step="1" />
                                    <span class="input-group-text bg-light text-muted small">cm</span>
                                </div>
                            </td>
                        </tr>
                        <!-- Fila 4: CANTIDAD CONOS Y LAMINADO -->
                        <tr>
                            <td class="fw-bold text-secondary bg-light">CANTIDAD</td>
                            <td><span id="resCantidadConos" class="fw-bold text-dark">@Model.MaquinaNumero</span></td>
                            <td colspan="2" class="text-start ps-3 small text-muted">conos</td>
                            <td class="fw-bold text-secondary bg-light">LAMINADO</td>
                            <td colspan="2">
                                <div class="input-group input-group-sm">
                                    <input asp-for="Laminado" class="form-control text-center calc-input fw-bold shadow-none" type="number" step="0.1" />
                                    <span class="input-group-text bg-light text-muted small">gm2</span>
                                </div>
                            </td>
                        </tr>
                        <!-- Fila 5: ANCHO, CORTE Y GML -->
                        <tr>
                            <td class="fw-bold text-secondary bg-light">MEDIDAS (Ancho x Corte)</td>
                            <td colspan="4">
                                <div class="d-flex justify-content-center align-items-center gap-2">
                                    <div class="input-group input-group-sm" style="max-width: 130px;">
                                        <input asp-for="Ancho" id="Ancho" class="form-control text-center calc-input fw-bold shadow-none" type="number" step="0.1" />
                                        <span class="input-group-text bg-light text-muted small">cm</span>
                                    </div>
                                    <span class="fw-bold text-muted">x</span>
                                    <div class="input-group input-group-sm" style="max-width: 130px;">
                                        <input asp-for="Corte" id="Corte" class="form-control text-center calc-input fw-bold shadow-none" type="number" step="0.1" />
                                        <span class="input-group-text bg-light text-muted small">cm</span>
                                    </div>
                                </div>
                            </td>
                            <td colspan="2" class="fw-bold text-success bg-light fs-6" id="resPesoMetro">
                                @Model.PesoMetroLineal.ToString("F1") gml
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- BLOQUE DE RESULTADOS -->
        <div class="card shadow-sm mb-4 border-0 rounded-3 overflow-hidden">
            <div class="card-header fw-bold text-center fs-5 text-white py-3" style="background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);">
                <i class="bi bi-bar-chart-fill me-2"></i> RESULTADOS
            </div>
            <div class="card-body p-0 table-responsive bg-white">
                <table class="table table-bordered align-middle mb-0 border-light" style="min-width: 650px;">
                    <tbody>
                        <tr>
                            <td class="fw-bold text-secondary bg-light" style="width: 15%;">PRODUCTO</td>
                            <td style="width: 20%;"><span class="fw-semibold text-dark" id="lblTipoProductoRes">@Model.TipoProducto</span></td>
                            <td rowspan="4" class="fw-bold text-white text-center align-middle" style="width: 12%; background-color: #1e3a8a;">RESISTENCIA</td>
                            <td class="bg-light fw-bold text-secondary" style="width: 15%;">URDIMBRE</td>
                            <td><span id="resUrdimbreRes2">@Model.ResistenciaUrdimbre.ToString("F2")</span> KgF</td>
                            <td><span id="resUrdimbrePorc2">@Model.PorcentajeUrdimbre.ToString("F0")</span> %</td>
                            <td rowspan="4" class="fw-bold text-white text-center align-middle" style="width: 12%; background-color: #1e3a8a;">PESO</td>
                            <td class="bg-light fw-bold text-secondary" style="width: 15%;">GM2</td>
                            <td class="fw-bold text-dark text-end bg-light" id="resPesoBase">@Model.PesoTejidoBase.ToString("F1")</td>
                        </tr>
                        <tr>
                            <td class="fw-bold text-secondary bg-light">MEDIDA</td>
                            <td><span class="fw-semibold text-dark" id="resMedida">@Model.Ancho x @Model.Corte</span></td>
                            <td class="bg-light fw-bold text-secondary">TRAMA</td>
                            <td><span id="resTramaRes2">@Model.ResistenciaTrama.ToString("F2")</span> KgF</td>
                            <td><span id="resTramaPorc2">@Model.PorcentajeTrama.ToString("F0")</span> %</td>
                            <td class="bg-light fw-bold text-secondary">GM2 (PP+LAM)</td>
                            <td class="fw-bold text-dark text-end bg-light" id="resPesoLaminado">@Model.PesoConLaminado.ToString("F1")</td>
                        </tr>
                        <tr>
                            <td class="fw-bold text-secondary bg-light">TEJIDO</td>
                            <td><span class="fw-semibold text-dark" id="resTejidoConcatenado">@Model.UrdimbreTejido x @Model.TramaTejido</span></td>
                            <td rowspan="2" class="fw-bold text-secondary bg-light align-middle">REFUERZO</td>
                            <td rowspan="2" class="align-middle text-center">
                                <div class="fw-bold text-primary" id="resUrdRefRes2">@Model.UrdimbreRefuerzoResistencia.ToString("F2") KgF</div>
                                <div class="text-muted small" id="resAnchoRefuerzoLabel">@Model.AnchoRefuerzoFactor cm</div>
                            </td>
                            <td rowspan="2" class="align-middle text-center fw-bold text-dark"><span id="resPorcRefuerzo">100</span> %</td>
                            <td class="bg-light fw-bold text-secondary">GMP</td>
                            <td class="fw-bold text-success text-end bg-light" id="resPesoRefuerzo">@Model.PesoConRefuerzo.ToString("F1")</td>
                        </tr>
                        <tr>
                            <td class="fw-bold text-secondary bg-light">DENIER</td>
                            <td><span class="fw-semibold text-dark" id="resDenierConcatenado">@Model.UrdimbreDenier x @Model.TramaDenier</span></td>
                            <td class="bg-light fw-bold text-secondary">GML</td>
                            <td class="fw-bold text-dark text-end bg-light" id="resPesoMetro2">@Model.PesoMetroLineal.ToString("F1")</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Botón de Guardar -->
        <div class="row">
            <div class="col-12">
                <button type="button" id="btnGuardar" class="btn w-100 py-3 fw-bold shadow text-uppercase tracking-wide text-white" style="background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%); border: none; transition: opacity 0.2s;">
                    <i class="bi bi-bookmark-check me-2"></i> Guardar Registro en Historial
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/calculadora.js"></script>
    <style>
        /* Optimizaciones responsivas para celulares */
        @media (max-width: 768px) {
            .container-fluid {
                padding-left: 8px !important;
                padding-right: 8px !important;
            }
            /* Evita el zoom automático en inputs en iOS y Android */
            input.form-control, select.form-select {
                font-size: 16px !important;
            }
            h2.fw-bold {
                font-size: 1.3rem;
            }
            .card-header {
                font-size: 0.9rem;
            }
        }
    </style>
}
