@model CalculadoraTela.ViewModels.CalculadoraTelaVM

@{
    ViewData["Title"] = "Calculadora de Tela";
}

<div class="container-fluid py-4 px-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="fw-bold text-dark mb-0">
            <i class="bi bi-file-earmark-spreadsheet text-success me-2"></i>TELA - Hoja de Cálculo
        </h2>
        <a asp-controller="Home" asp-action="Historial" class="btn btn-outline-secondary shadow-sm">
            <i class="bi bi-clock-history me-1"></i> Ver Historial
        </a>
    </div>

    <form id="calcForm">
        <!-- MATRIZ DE CONFIGURACIÓN Y TEJIDO -->
        <div class="card shadow-sm mb-4 border-dark">
            <div class="card-header header-matriz fw-bold d-flex justify-content-between align-items-center">
                <span><i class="bi bi-table me-2"></i> MATRIZ DE CONFIGURACIÓN Y TEJIDO</span>
                <div class="d-flex align-items-center gap-2">
                    <label asp-for="TipoProducto" class="text-white small mb-0">Tipo Producto:</label>
                    <select asp-for="TipoProducto" class="form-select form-select-sm text-dark fw-bold calc-input" id="TipoProducto" style="width: 140px;">
                        <option value="Plana">Plana</option>
                        <option value="Tubular">Tubular</option>
                    </select>
                </div>
            </div>
            <div class="card-body p-0 table-responsive">
                <table class="table table-bordered align-middle text-center mb-0 border-dark">
                    <thead class="table-secondary text-dark">
                        <tr>
                            <th style="width: 14%;">ITEM</th>
                            <th style="width: 14%;">TEJIDO</th>
                            <th style="width: 14%;">CINTA</th>
                            <th style="width: 14%;">DENIER</th>
                            <th style="width: 16%;">RESISTENCIA</th>
                            <th colspan="2" style="width: 28%;">PESO</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Fila 1: URDIMBRE -->
                        <tr class="fila-base">
                            <td class="fw-bold bg-light">URDIMBRE</td>
                            <td><input asp-for="UrdimbreTejido" class="form-control form-control-sm text-center calc-input fw-bold" type="number" step="0.1" /></td>
                            <td>
                                <div class="input-group input-group-sm">
                                    <input asp-for="CintaUrdimbre" class="form-control text-center calc-input fw-bold" type="number" step="0.1" />
                                    <span class="input-group-text bg-light">mm</span>
                                </div>
                            </td>
                            <td><input asp-for="UrdimbreDenier" class="form-control form-control-sm text-center calc-input fw-bold" type="number" step="1" /></td>
                            <td><span id="resUrdimbreRes" class="fw-bold text-primary">@Model.ResistenciaUrdimbre.ToString("F2") KgF</span></td>
                            <td><span id="resUrdimbrePeso">@Model.PesoUrdimbre.ToString("F2") gr</span></td>
                            <td><span id="resUrdimbrePorc" class="badge badge-porcentaje">@Model.PorcentajeUrdimbre.ToString("F1") %</span></td>
                        </tr>
                        <!-- Fila 2: TRAMA -->
                        <tr class="fila-base">
                            <td class="fw-bold bg-light">TRAMA</td>
                            <td><input asp-for="TramaTejido" class="form-control form-control-sm text-center calc-input fw-bold" type="number" step="0.1" /></td>
                            <td>
                                <div class="input-group input-group-sm">
                                    <input asp-for="CintaTrama" class="form-control text-center calc-input fw-bold" type="number" step="0.1" />
                                    <span class="input-group-text bg-light">mm</span>
                                </div>
                            </td>
                            <td><input asp-for="TramaDenier" class="form-control form-control-sm text-center calc-input fw-bold" type="number" step="1" /></td>
                            <td><span id="resTramaRes" class="fw-bold text-primary">@Model.ResistenciaTrama.ToString("F2") KgF</span></td>
                            <td><span id="resTramaPeso">@Model.PesoTrama.ToString("F2") gr</span></td>
                            <td><span id="resTramaPorc" class="badge badge-porcentaje">@Model.PorcentajeTrama.ToString("F1") %</span></td>
                        </tr>
                        <!-- Fila 3: URDIMBRE REFUERZO -->
                        <tr class="fila-refuerzo">
                            <td class="fw-bold etiqueta-refuerzo">URDIMBRE REF.</td>
                            <td><input asp-for="UrdimbreRefuerzoTejido" class="form-control form-control-sm text-center calc-input fw-bold" type="number" step="0.1" /></td>
                            <td>
                                <div class="input-group input-group-sm">
                                    <input asp-for="CintaRefuerzo" class="form-control text-center calc-input fw-bold" type="number" step="0.1" />
                                    <span class="input-group-text bg-light">mm</span>
                                </div>
                            </td>
                            <td><input asp-for="DenierRefuerzo" class="form-control form-control-sm text-center calc-input fw-bold" type="number" step="1" /></td>
                            <td><span id="resUrdRefRes" class="fw-bold text-primary">@Model.UrdimbreRefuerzoResistencia.ToString("F2") KgF</span></td>
                            <td class="etiqueta-refuerzo text-start ps-2">ANCHO REFUERZO</td>
                            <td>
                                <div class="input-group input-group-sm">
                                    <!-- Validación estricta min="0" max="12" según requerimiento de la Hoja 2 -->
                                    <input asp-for="AnchoRefuerzoFactor" class="form-control text-center calc-input fw-bold" type="number" min="0" max="12" step="1" />
                                    <span class="input-group-text celda-refuerzo">cm</span>
                                </div>
                            </td>
                        </tr>
                        <!-- Fila 4: CANTIDAD CONOS Y LAMINADO -->
                        <tr>
                            <td class="fw-bold bg-light">CANTIDAD</td>
                            <td><span id="resCantidadConos" class="fw-bold">@Model.MaquinaNumero</span></td>
                            <td colspan="2" class="text-start ps-2 small text-muted">conos</td>
                            <td class="fw-bold bg-light">LAMINADO</td>
                            <td colspan="2">
                                <div class="input-group input-group-sm">
                                    <input asp-for="Laminado" class="form-control text-center calc-input fw-bold" type="number" step="0.1" />
                                    <span class="input-group-text bg-light">gm2</span>
                                </div>
                            </td>
                        </tr>
                        <!-- Fila 5: ANCHO Y GML -->
                        <tr>
                            <td class="fw-bold bg-light">ANCHO</td>
                            <td colspan="4">
                                <div class="input-group input-group-sm justify-content-center">
                                    <input asp-for="Ancho" class="form-control text-center calc-input fw-bold" type="number" step="0.1" style="max-width: 150px;" />
                                    <span class="input-group-text bg-light">cm</span>
                                </div>
                            </td>
                            <td colspan="2" class="celda-resultado-excel destacado" id="resPesoMetro">
                                @Model.PesoMetroLineal.ToString("F1") gml
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- BLOQUE DE RESULTADOS -->
        <div class="card shadow-sm mb-4 border-warning">
            <div class="card-header header-resultados fw-bold text-center fs-5">
                <i class="bi bi-bar-chart-fill me-2"></i> RESULTADOS
            </div>
            <div class="card-body p-0">
                <table class="table table-bordered align-middle mb-0 border-dark">
                    <tbody>
                        <tr>
                            <td class="fw-bold bg-light" style="width: 15%;">PRODUCTO</td>
                            <td style="width: 20%;"><span class="fw-semibold" id="lblTipoProductoRes">@Model.TipoProducto</span></td>
                            <td rowspan="4" class="fw-bold bg-secondary text-white text-center align-middle" style="width: 12%;">RESISTENCIA</td>
                            <td class="bg-light fw-bold" style="width: 15%;">URDIMBRE</td>
                            <td><span id="resUrdimbreRes2">@Model.ResistenciaUrdimbre.ToString("F2")</span> KgF</td>
                            <td><span id="resUrdimbrePorc2">@Model.PorcentajeUrdimbre.ToString("F0")</span> %</td>
                            <td rowspan="4" class="fw-bold bg-secondary text-white text-center align-middle" style="width: 12%;">PESO</td>
                            <td class="bg-light fw-bold" style="width: 15%;">GM2</td>
                            <td class="celda-resultado-excel text-end" id="resPesoBase">@Model.PesoTejidoBase.ToString("F1")</td>
                        </tr>
                        <tr>
                            <td class="fw-bold bg-light">MEDIDA</td>
                            <td><span class="fw-semibold" id="resMedida">@Model.Ancho x @Model.Corte</span></td>
                            <td class="bg-light fw-bold">TRAMA</td>
                            <td><span id="resTramaRes2">@Model.ResistenciaTrama.ToString("F2")</span> KgF</td>
                            <td><span id="resTramaPorc2">@Model.PorcentajeTrama.ToString("F0")</span> %</td>
                            <td class="bg-light fw-bold">GM2 (PP+LAM)</td>
                            <td class="celda-resultado-excel text-end" id="resPesoLaminado">@Model.PesoConLaminado.ToString("F1")</td>
                        </tr>
                        <tr>
                            <td class="fw-bold bg-light">TEJIDO</td>
                            <td><span class="fw-semibold" id="resTejidoConcatenado">@Model.UrdimbreTejido x @Model.TramaTejido</span></td>
                            <td rowspan="2" class="fw-bold etiqueta-refuerzo align-middle">REFUERZO</td>
                            <td rowspan="2" class="celda-refuerzo align-middle"><span id="resUrdRefRes2">@Model.UrdimbreRefuerzoResistencia.ToString("F2")</span> KgF</td>
                            <td rowspan="2" class="celda-refuerzo align-middle"><span id="resAnchoRefuerzoLabel">@Model.AnchoRefuerzoFactor</span> cm</td>
                            <td class="bg-light fw-bold">GMP</td>
                            <td class="celda-gmp text-end" id="resPesoRefuerzo">@Model.PesoConRefuerzo.ToString("F1")</td>
                        </tr>
                        <tr>
                            <td class="fw-bold bg-light">DENIER</td>
                            <td><span class="fw-semibold" id="resDenierConcatenado">@Model.UrdimbreDenier x @Model.TramaDenier</span></td>
                            <td class="bg-light fw-bold">GML</td>
                            <td class="celda-resultado-excel text-end" id="resPesoMetro2">@Model.PesoMetroLineal.ToString("F1")</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <button type="button" id="btnGuardar" class="btn btn-primary w-100 py-3 fw-bold shadow">
                    <i class="bi bi-bookmark-check me-2"></i> Guardar Registro en Historial
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/calculadora.js"></script>
}
