@model IEnumerable<CalculadoraTela.ViewModels.RendimientoVM>

@{
    ViewData["Title"] = "Control de Rendimiento";
}

<style>
    body { background-color: #f8fafc; }
    .bg-dark-blue { background-color: #0f172a !important; }
    .kpi-card { transition: transform 0.2s; }
    .kpi-card:hover { transform: translateY(-3px); }
</style>

<!-- Navbar Superior (Plan C - Módulo Operaciones) -->
<nav class="navbar navbar-dark bg-dark-blue shadow-sm mb-4">
    <div class="container-fluid px-4">
        <a class="navbar-brand fw-bold d-flex align-items-center" href="/Home/Index">
            <i class="bi bi-cpu me-2"></i> Calculadora Tela
        </a>
        <div class="d-flex text-white-50 align-items-center gap-3">
            <a href="/Home/Index" class="text-white-50 text-decoration-none small">
                <i class="bi bi-calculator me-1"></i> Ficha Técnica
            </a>
            <a href="/Home/Historial" class="text-white-50 text-decoration-none small">
                <i class="bi bi-clock-history me-1"></i> Historial BD
            </a>

            <span class="text-white-50">|</span>

            <!-- Menú Operaciones -->
            <div class="dropdown d-inline">
                <a class="text-warning text-decoration-none small dropdown-toggle fw-bold" href="#" role="button" data-bs-toggle="dropdown">
                    <i class="bi bi-graph-up me-1"></i> Rendimiento (%)
                </a>
                <ul class="dropdown-menu dropdown-menu-dark shadow">
                    <li><a class="dropdown-item small active bg-warning text-dark" href="/Operaciones/Rendimiento"><i class="bi bi-graph-up me-2"></i>Rendimiento (%)</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item small" href="/Operaciones/Ausencias?tipo=Asistencia"><i class="bi bi-person-check me-2"></i>Asistencia</a></li>
                    <li><a class="dropdown-item small" href="/Operaciones/Ausencias?tipo=Falta"><i class="bi bi-person-x me-2"></i>Faltas</a></li>
                    <li><a class="dropdown-item small" href="/Operaciones/Ausencias?tipo=Vacaciones"><i class="bi bi-calendar-event me-2"></i>Vacaciones / Bajas</a></li>
                    <li><a class="dropdown-item small" href="/Operaciones/Ausencias?tipo=NoEnMaquina"><i class="bi bi-slash-circle me-2"></i>No en Máquina</a></li>
                </ul>
            </div>
        </div>
    </div>
</nav>

<div class="container-fluid px-4 pb-5">

    <!-- Encabezado de Sección -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-0">
                <i class="bi bi-speedometer2 text-warning me-2"></i>Rendimiento y Eficiencia de Planta
            </h3>
            <p class="text-muted small mb-0">Monitoreo de producción real frente a producción teórica estimada.</p>
        </div>
        <div>
            <button class="btn btn-success btn-sm rounded-3 shadow-sm fw-bold px-3" onclick="guardarCambiosRendimiento()">
                <i class="bi bi-floppy me-1"></i> Guardar Registros
            </button>
        </div>
    </div>

    <!-- Tarjetas KPI Resumen -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-3 bg-white p-3 kpi-card border-start border-4 border-primary">
                <small class="text-muted text-uppercase fw-semibold d-block mb-1" style="font-size: 0.75rem;">Eficiencia Promedio Planta</small>
                <div class="d-flex align-items-baseline justify-content-between">
                    <span class="fs-2 fw-bold text-primary" id="kpiPromedioEficiencia">0.0%</span>
                    <span class="badge bg-primary-subtle text-primary rounded-pill px-2 py-1">Meta: 85%</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-3 bg-white p-3 kpi-card border-start border-4 border-success">
                <small class="text-muted text-uppercase fw-semibold d-block mb-1" style="font-size: 0.75rem;">Máquinas Activas</style>
                <div class="d-flex align-items-baseline justify-content-between">
                    <span class="fs-2 fw-bold text-success" id="kpiMaquinasActivas">18</span>
                    <span class="badge bg-success-subtle text-success rounded-pill px-2 py-1">100% Operativo</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-3 bg-white p-3 kpi-card border-start border-4 border-warning">
                <small class="text-muted text-uppercase fw-semibold d-block mb-1" style="font-size: 0.75rem;">Producción Total Real</small>
                <div class="d-flex align-items-baseline justify-content-between">
                    <span class="fs-2 fw-bold text-dark" id="kpiProduccionTotal">0</span>
                    <small class="text-muted fw-semibold">metros</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla Dinámica de Eficiencia -->
    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="tablaRendimiento">
                    <thead class="bg-light text-secondary small text-uppercase">
                        <tr>
                            <th class="ps-4">Máquina</th>
                            <th>Operario</th>
                            <th class="text-center">Prod. Teórica (m)</th>
                            <th class="text-center" style="width: 180px;">Prod. Real (m)</th>
                            <th class="text-center" style="width: 180px;">% Eficiencia</th>
                            <th class="text-center pe-4">Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 1; i <= 18; i++)
                        {
                            <tr id="row-maq-@i">
                                <td class="ps-4 fw-bold">
                                    <span class="badge bg-dark px-2 py-1">M-@i</span>
                                </td>
                                <td>
                                    <input type="text" class="form-control form-control-sm input-operario" placeholder="Nombre de operario..." value="Operario @i">
                                </td>
                                <td class="text-center font-monospace fw-semibold text-secondary">
                                    <span class="prod-teorica" data-base="1500">1,500.00</span> m
                                </td>
                                <td>
                                    <input type="number" step="0.1" class="form-control form-control-sm text-center fw-bold input-prod-real" value="1350" oninput="calcularFila(@i)">
                                </td>
                                <td class="text-center">
                                    <span class="fs-6 fw-bold lbl-eficiencia" id="eficiencia-@i">90.0%</span>
                                </td>
                                <td class="text-center pe-4">
                                    <span class="badge bg-success badge-estado" id="estado-@i">Óptimo</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Calcular todos los totales al cargar la página
            for (let i = 1; i <= 18; i++) {
                calcularFila(i);
            }
        });

        function calcularFila(id) {
            const row = document.getElementById(`row-maq-${id}`);
            const teorica = parseFloat(row.querySelector('.prod-teorica').getAttribute('data-base')) || 1;
            const realInput = row.querySelector('.input-prod-real');
            let real = parseFloat(realInput.value) || 0;

            let eficiencia = (real / teorica) * 100;
            
            const lblEficiencia = document.getElementById(`eficiencia-${id}`);
            const badgeEstado = document.getElementById(`estado-${id}`);

            lblEficiencia.innerText = `${eficiencia.toFixed(1)}%`;

            // Formateo visual dinámico según el porcentaje obtenido
            if (eficiencia >= 85) {
                lblEficiencia.className = "fs-6 fw-bold text-success";
                badgeEstado.className = "badge bg-success";
                badgeEstado.innerText = "Óptimo";
            } else if (eficiencia >= 70) {
                lblEficiencia.className = "fs-6 fw-bold text-warning";
                badgeEstado.className = "badge bg-warning text-dark";
                badgeEstado.innerText = "Regular";
            } else {
                lblEficiencia.className = "fs-6 fw-bold text-danger";
                badgeEstado.className = "badge bg-danger";
                badgeEstado.innerText = "Bajo";
            }

            actualizarTotalesGlobales();
        }

        function actualizarTotalesGlobales() {
            let totalReal = 0;
            let sumaPorcentajes = 0;
            let totalMaquinas = 18;

            for (let i = 1; i <= totalMaquinas; i++) {
                const row = document.getElementById(`row-maq-${i}`);
                const real = parseFloat(row.querySelector('.input-prod-real').value) || 0;
                const teorica = parseFloat(row.querySelector('.prod-teorica').getAttribute('data-base')) || 1;
                
                totalReal += real;
                sumaPorcentajes += (real / teorica) * 100;
            }

            let promedioGlobal = sumaPorcentajes / totalMaquinas;

            document.getElementById('kpiPromedioEficiencia').innerText = `${promedioGlobal.toFixed(1)}%`;
            document.getElementById('kpiProduccionTotal').innerText = totalReal.toLocaleString('es-ES', { minimumFractionDigits: 1, maximumFractionDigits: 1 });
        }

        function guardarCambiosRendimiento() {
            alert('Registros de rendimiento procesados y respaldados exitosamente.');
        }
    </script>
}
